# UltraMsg Configuration (WhatsApp Reminders)
ULTRAMSG_INSTANCE_ID=your_instance_id_here
ULTRAMSG_TOKEN=your_token_here
MOCK_WHATSAPP=false

# Database Configuration (SQLite)
# Stored inside the ignored data/ folder for local persistence
DATABASE_PATH=data/pharma_ops.db

# Business Logic Configuration
# Expiry window in days (reminders sent for batches expiring within this number of days)
RETURN_WINDOW_DAYS=90
